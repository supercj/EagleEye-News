{
  "manifest_version": 3,
  "name": "EagleEye News",
  "description": "鹰眼资讯：无服务器的 Chrome/Edge 热点资讯聚合扩展，支持导入订阅源并在本地保存收藏与已读状态。",
  "version": "0.1.0",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "EagleEye News",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "src/options.html",
  "permissions": [
    "alarms",
    "storage",
    "permissions"
  ],
  "host_permissions": [
    "https://abcnews.go.com/*",
    "https://www.cbsnews.com/*",
    "https://feeds.skynews.com/*",
    "https://feeds.npr.org/*",
    "https://36kr.com/*",
    "https://rss.sina.com.cn/*",
    "http://www.people.com.cn/*",
    "https://www.tmtpost.com/*",
    "https://www.leiphone.com/*",
    "https://www.oschina.net/*",
    "https://feed.cnblogs.com/*",
    "https://hacker-news.firebaseio.com/*",
    "https://github.com/trending*",
    "https://github.blog/*",
    "https://stackoverflow.blog/*",
    "https://linux.do/*",
    "https://www.solidot.org/*",
    "https://www.infoq.cn/*",
    "https://www.ifanr.com/*",
    "https://www.ithome.com/*",
    "https://sspai.com/*",
    "https://www.v2ex.com/*",
    "https://www.producthunt.com/*",
    "https://www.theverge.com/*",
    "https://techcrunch.com/*",
    "https://feeds.arstechnica.com/*",
    "https://www.wired.com/*",
    "https://www.zdnet.com/*",
    "https://readhub.cn/*",
    "https://juejin.cn/*",
    "https://hellogithub.com/*",
    "https://www.qbitai.com/*",
    "https://www.cnbc.com/*",
    "https://www.nasdaq.com/*",
    "https://feeds.content.dowjones.io/*",
    "https://seekingalpha.com/*",
    "https://rsshub.app/*",
    "https://bbs.hupu.com/*",
    "https://www.52pojie.cn/*",
    "https://www.bilibili.com/*"
  ],
    "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "打开 EagleEye News"
    }
  },"optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
